                "GET /agents/{guid}",
                "GET /offices",
                "GET /offices/{moxi_works_office_id}",
                "GET /teams",
                "GET /teams/{moxi_works_team_id}"
              ]
            },
            {
              "group": "Listings",
              "expanded": true,
              "openapi": "windermereapi(1).json",
              "pages": [
                "GET /listings",
                "GET /listings/{moxi_works_listing_id}",
                "GET /sold_listings",
                "GET /sold_listings/{moxi_works_listing_id}"
              ]
            },
            {
              "group": "Company",
              "expanded": true,
              "openapi": "windermereapi(1).json",
              "pages": [
                "GET /companies",
                "GET /companies/{moxi_works_company_id}"
              ]
            }
          ]
        }
      ]
    }
  ]
},
  "logo": {
    "light": "/images/WRE_logo_HORIZ_CLR_resized.png",
