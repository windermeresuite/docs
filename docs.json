{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Windermere Real Estate API",
  "colors": {
    "primary": "#009cde",
    "light": "#009cde",
    "dark": "#002a4e"
  },
  "favicon": "/images/favicon-32x32.png",
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Documentation",
          "icon": "book-open-cover",
          "href": "https://mintlify.com/docs"
        },
        {
          "anchor": "Blog",
          "icon": "newspaper",
          "href": "https://mintlify.com/blog"
        }
      ]
    },
    "products": [
      {
        "product": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
              "index",
              "quickstart",
              "development"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "essentials/settings",
              "essentials/navigation"
            ]
          },
          {
            "group": "Writing content",
            "pages": [
              "essentials/markdown",
              "essentials/code",
              "essentials/images",
              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "product": "API reference",
        "groups": [
          {
            "group": "API documentation",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoint examples",
            "openapi": "windermereapi.json"
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/images/WRE_logo_HORIZ_CLR_resized.png",
    "dark": "/images/WRE_logo_HORIZ_REV_resized.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Developer Portal",
        "href": "/"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Dashboard",
      "href": "https://dashboard.mintlify.com"
    }
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "api": {
    "openapi": "/windermereapi.json"
  },
  "fonts": {
    "family": "Montserrat",
    "weight": 400,
    "heading": {
      "family": "Montserrat",
      "weight": 500
    },
    "body": {
      "family": "Montserrat",
      "weight": 400
    }
  }
}
